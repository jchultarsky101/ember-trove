# ── Ember Trove — Local Development Secrets ───────────────────────────────────
# Copy this file to deploy/.env.local and fill in real values.
# NEVER commit deploy/.env.local to git (it is gitignored).
#
# Usage:
#   docker compose -f deploy/docker-compose.yml --env-file deploy/.env.local up --build
#
# These values override the "change-me" placeholders in docker-compose.yml.
# All other env vars (DATABASE_URL, S3_*, ports, etc.) are fine as defaults.

# ── Cognito OIDC ──────────────────────────────────────────────────────────────
# Find in: AWS Console → Cognito → User Pools → ember-trove → App clients → Show client secret
OIDC_CLIENT_SECRET=CHANGE_ME

# ── Cognito Admin (ember-trove-api IAM user) ──────────────────────────────────
# Used by /api/admin/* endpoints (user management).
# Find in: AWS Console → IAM → Users → ember-trove → Security credentials → Access keys
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
