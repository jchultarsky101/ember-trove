# ── Ember Trove — Production Environment ──────────────────────────────────────
# Copy this file to .env.prod and fill in real values.
# NEVER commit .env.prod to git.
#
# Generate POSTGRES_PASSWORD:  openssl rand -hex 16
# Generate COOKIE_KEY:         openssl rand -hex 64

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME

# ── Lightsail Object Storage ──────────────────────────────────────────────────
# Access keys from: Lightsail console → Storage → your bucket → Permissions → Access keys
S3_BUCKET=CHANGE_ME
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME

# ── Cognito OIDC ──────────────────────────────────────────────────────────────
OIDC_CLIENT_SECRET=CHANGE_ME

# ── Cognito Admin (ember-trove-api IAM user) ──────────────────────────────────
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME

# ── Cookie encryption (128 hex chars = 64 bytes) ──────────────────────────────
COOKIE_KEY=CHANGE_ME

# ── Automated backups (deploy/backup.sh) ──────────────────────────────────────
# BACKUP_BUCKET defaults to S3_BUCKET; override to use a dedicated backup bucket.
# BACKUP_BUCKET=CHANGE_ME
# BACKUP_PREFIX=backups
# BACKUP_RETAIN=30
# S3_ENDPOINT=             # leave empty for native AWS S3; set for MinIO/Lightsail custom endpoint
# Cron: 0 2 * * * /home/ubuntu/ember-trove/deploy/backup.sh >> /var/log/ember-backup.log 2>&1
